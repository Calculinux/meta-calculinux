#!/bin/sh

echo "PREINIT: Start"

PATH=/sbin:/bin:/usr/sbin:/usr/bin
mount -o remount,rw /

mkdir -p /proc
mkdir -p /sys
mkdir -p /run
mkdir -p /var/run

mount -t proc proc /proc
mount -t sysfs sysfs /sys

[ -z "$CONSOLE" ] && CONSOLE="/dev/console"

OVERLAYS="/etc /root /home /var /usr /opt"

#Grow the overlay partition to fill disk
PARTITION_NAME="$(lsblk -n -r -o NAME -Q 'PARTLABEL =~ "{OVERLAYFS_ETC_DEVICE}"')"
PARTITION_DISK="$(lsblk -n -r -o PKNAME -Q 'PARTLABEL =~ "{OVERLAYFS_ETC_DEVICE}"')"
PARTITION_NUM="$(lsblk -n -r -o PARTN -Q 'PARTLABEL =~ "{OVERLAYFS_ETC_DEVICE}"')"

if growpart --free-percent=10 "$PARTITION_DISK" $PARTITION_NUM; then
  e2fsck -y -f "/dev/$PARTITION_NAME"
  resize2fs "/dev/$PARTITION_NAME"
fi

# Ensure ext4 has xattrs enabled (e.g. if partition was created without ext_attr)
if [ "{OVERLAYFS_ETC_FSTYPE}" = "ext4" ]; then
  tune2fs -O ext_attr "/dev/$PARTITION_NAME" 2>/dev/null || true
fi

mkdir -p {OVERLAYFS_ETC_MOUNT_POINT}
DATA_MOUNTED=
if mount -n -t {OVERLAYFS_ETC_FSTYPE} \
    -o {OVERLAYFS_ETC_MOUNT_OPTIONS} \
    "/dev/$PARTITION_NAME" {OVERLAYFS_ETC_MOUNT_POINT}
then
    DATA_MOUNTED=1
fi
if [ -z "$DATA_MOUNTED" ]; then
    echo "PREINIT: </data> mount failed, attempting format..."
    mkfs.ext4 -F -O ext_attr "/dev/$PARTITION_NAME" 2>/dev/null && \
    mount -n -t {OVERLAYFS_ETC_FSTYPE} \
        -o {OVERLAYFS_ETC_MOUNT_OPTIONS} \
        "/dev/$PARTITION_NAME" {OVERLAYFS_ETC_MOUNT_POINT} && \
    DATA_MOUNTED=1
fi
if [ -n "$DATA_MOUNTED" ]; then
    # Seed /data/fit/ with both A and B from read-only /boot/zboot_merged.img when either is missing
    FIT_A="{OVERLAYFS_ETC_MOUNT_POINT}/fit/zboot_merged_a.img"
    FIT_B="{OVERLAYFS_ETC_MOUNT_POINT}/fit/zboot_merged_b.img"
    DEFAULT_FIT="/boot/zboot_merged.img"
    if [ -f "$DEFAULT_FIT" ] && {{ [ ! -f "$FIT_A" ] || [ ! -f "$FIT_B" ]; }}; then
        echo "PREINIT: Seeding /data/fit/ with default merged FIT and rebooting..."
        mkdir -p "{OVERLAYFS_ETC_MOUNT_POINT}/fit"
        cp "$DEFAULT_FIT" "$FIT_A"
        cp "$DEFAULT_FIT" "$FIT_B"
        fw_setenv DEFAULT_FIT_JUST_INSTALLED 1 2>/dev/null || true
        fw_setenv FIT_SLOT A 2>/dev/null || true
        fw_setenv BOOT_A_LEFT 3 2>/dev/null || true
        fw_setenv BOOT_B_LEFT 3 2>/dev/null || true
        sync
        reboot -f
    fi
fi
if [ -n "$DATA_MOUNTED" ]; then
    for overlay in $OVERLAYS; do
        echo ">> Mounting overlay for: $overlay"

        BASE="{OVERLAYFS_ETC_MOUNT_POINT}/overlay/$overlay"
        LOWER_DIR="$BASE/lower"
        UPPER_DIR="$BASE/upper"
        WORK_DIR="$BASE/work"

        mkdir -p $UPPER_DIR
        mkdir -p $WORK_DIR

        if {OVERLAYFS_ETC_EXPOSE_LOWER}; then
            mkdir -p $LOWER_DIR

            # provide read-only access to original /etc content
            mount -o bind,ro $overlay $LOWER_DIR
        fi

        mount -n -t overlay \
              -o upperdir=$UPPER_DIR \
              -o lowerdir=$overlay \
              -o workdir=$WORK_DIR \
              -o index=off,xino=off,redirect_dir=off,metacopy=off \
              $UPPER_DIR $overlay || \
            echo "PREINIT: Mounting $overlay failed!"

    done
else
    echo "PREINIT: Mounting </data> failed!"
fi

echo "PREINIT: done; starting </sbin/init>"
exec {SBIN_INIT_NAME}
